# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=host1.com,host2.com
CSRF_TRUSTED_ORIGINS=https://host1.com,https://host2.com
FORCE_SCRIPT_NAME=/expense-tracker
DB_PATH=/app/data/db.sqlite3

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=your-site-key
